# Copy this file to .env and fill in your values.
# Never commit .env to Git!

PORT=5000
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

JWT_SECRET=<generate-a-64-char-random-hex-string>
JWT_EXPIRE=7d

# Set to 'production' on Render, 'development' locally
NODE_ENV=development

# Allowed CORS origin — set to your Vercel frontend URL in production
CLIENT_URL=http://localhost:5173

# Default admin credentials — change after first login and then REMOVE these lines
ADMIN1_EMAIL=admin1@school.com
ADMIN1_PASSWORD=<your-strong-password>
ADMIN2_EMAIL=admin2@school.com
ADMIN2_PASSWORD=<your-strong-password>
ADMIN1_NAME=Principal Admin
ADMIN2_NAME=Vice Principal

# Comma-separated emails allowed to view/clear activity logs
LOG_AUTHORIZED_EMAILS=admin1@school.com,admin2@school.com

# Gmail App Password (generate at https://myaccount.google.com/apppasswords)
SMTP_EMAIL=<your-gmail>@gmail.com
SMTP_PASSWORD=<your-gmail-app-password>

# Google OAuth Client ID (from Google Cloud Console)
GOOGLE_CLIENT_ID=<your-google-client-id>.apps.googleusercontent.com

# Twilio SMS (optional — leave empty to use mock SMS in development)
# TWILIO_ACCOUNT_SID=<your-twilio-sid>
# TWILIO_AUTH_TOKEN=<your-twilio-auth-token>
# TWILIO_PHONE_NUMBER=<your-twilio-phone>
